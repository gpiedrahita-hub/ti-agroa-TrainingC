{
  "name": "infinite-herbs-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:dev:migrate": "dotenv -e .env.local -- npx prisma migrate dev",
    "prisma:dev:seed": "dotenv -e .env.local -- npx prisma db seed",
    "prisma:prod:deploy": "dotenv -e .env.production -- npx prisma migrate deploy",
    "prisma:prod:seed": "dotenv -e .env.production -- npx prisma db seed",
    "prisma:test:reset": "dotenv -e .env.test -- npx prisma migrate reset --force",
    "prisma:test:seed": "dotenv -e .env.test -- npx prisma db seed"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
